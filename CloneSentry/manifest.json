{
  "manifest_version": 3,
  "name": "SpecterScan",
  "version": "1.0",
  "description": "AI-powered phishing protection with strict privacy.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://spectarscan.onrender.com/*"
  ],
  "action": {
    "default_popup": "ui/popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "content_scripts": [
  {
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }
]
}